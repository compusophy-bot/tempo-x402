# ===========================================================================
# tempo-x402 Node Configuration
# ===========================================================================
# The node auto-bootstraps most settings. Only GEMINI_API_KEY is required
# for full functionality. Everything else has sensible defaults.

# ===========================================================================
# REQUIRED — AI & Identity
# ===========================================================================

# Gemini API key for the soul's cognitive loop (dormant without it)
GEMINI_API_KEY=your-gemini-api-key

# ===========================================================================
# BLOCKCHAIN — Tempo Moderato (auto-configured defaults)
# ===========================================================================

# RPC endpoint (default: https://rpc.moderato.tempo.xyz)
# RPC_URL=https://rpc.moderato.tempo.xyz

# Private key (auto-generated via AUTO_BOOTSTRAP if not set)
# EVM_PRIVATE_KEY=0x...

# HMAC shared secret for embedded facilitator (auto-generated if not set)
# FACILITATOR_SHARED_SECRET=your-secret

# ===========================================================================
# SOUL — Cognitive Architecture
# ===========================================================================

# Enable code editing, committing, pushing (default: true)
# SOUL_CODING_ENABLED=true

# Fork repo for agent code push (e.g. compusophy-bot/tempo-x402)
# SOUL_FORK_REPO=compusophy-bot/tempo-x402

# Upstream repo for PRs/issues (e.g. compusophy/tempo-x402)
# SOUL_UPSTREAM_REPO=compusophy/tempo-x402

# Push directly to fork's main branch (default: true for queen, false for clones)
# SOUL_DIRECT_PUSH=true

# Benchmark mode: "opus" (50 novel problems) or "exercism" (164 exercises)
# SOUL_BENCHMARK_MODE=opus

# Persistent memory file path (default: /data/soul_memory.md)
# SOUL_MEMORY_FILE=/data/soul_memory.md

# ===========================================================================
# CLONE ORCHESTRATION — Railway
# ===========================================================================

# Railway API token (required for clone operations)
# RAILWAY_TOKEN=your-railway-token

# GitHub token for fork operations
# GITHUB_TOKEN=ghp_...

# Clone source repo (default: SOUL_FORK_REPO)
# CLONE_SOURCE_REPO=compusophy-bot/tempo-x402

# Clone price in pathUSD (default: $1.00)
# CLONE_PRICE=$1.00

# Maximum children (default: 10)
# CLONE_MAX_CHILDREN=10

# ===========================================================================
# SECURITY & ADMIN
# ===========================================================================

# Admin token for /soul/admin/* endpoints (default: first 16 chars of GEMINI_API_KEY)
# SOUL_ADMIN_TOKEN=your-admin-token

# Metrics endpoint auth (default: not set = publicly accessible)
# METRICS_TOKEN=your-metrics-token

# Comma-separated CORS origins
# ALLOWED_ORIGINS=https://yourdomain.com

# Rate limit per minute per IP (default: 60)
# RATE_LIMIT_RPM=60

# ===========================================================================
# INFRASTRUCTURE
# ===========================================================================

# Auto-bootstrap identity (generates wallet, funds via faucet)
# AUTO_BOOTSTRAP=true

# Database paths (defaults to /data/)
# DB_PATH=/data/gateway.db
# SOUL_DB_PATH=/data/soul.db

# Health probe interval in seconds (default: 300)
# HEALTH_PROBE_INTERVAL_SECS=300

# ===========================================================================
# CHAIN REFERENCE
# ===========================================================================
# Chain: Tempo Moderato (ID 42431)
# Token: pathUSD (0x20c0000000000000000000000000000000000000, 6 decimals)
# RPC: https://rpc.moderato.tempo.xyz
# Explorer: https://explore.moderato.tempo.xyz
# Faucet: cast rpc tempo_fundAddress <ADDR> --rpc-url https://rpc.moderato.tempo.xyz
